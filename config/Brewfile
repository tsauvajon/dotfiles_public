# Public Homebrew-managed casks managed by setup.sh.
#
# `setup.sh` reconciles this file plus the optional generated personal
# Brewfile at ~/.config/dotfiles-managed/Brewfile.personal after Home
# Manager activation. Anything listed in either file will be installed with
# Homebrew if missing; any Homebrew cask absent from both files will be
# removed.
#
# To inspect extra casks without removing them, run `scripts/brew-cleanup.sh`.
#
# Add an entry only if a cask cannot (or should not) be Nix-managed:
# - `gimp` and `vlc` are not built for aarch64-darwin in current nixpkgs
#   (`meta.platforms` excludes Darwin).
# - `visual-studio-code` is intentionally kept on Brew alongside the
#   Nix-managed `vscodium` so both editors coexist.

cask "gimp"
cask "vlc"
cask "visual-studio-code"
