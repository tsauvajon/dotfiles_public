{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4.6",
  "small_model": "anthropic/claude-sonnet-4.6",
  "theme": "opencode",
  "autoupdate": false,
  "share": "manual",
  "watcher": {
    "ignore": [
      ".git/**",
      ".direnv/**",
      "node_modules/**",
      "target/**",
      "dist/**",
      "build/**"
    ]
  },
  "command": {
    "aggressive-testing": {
      "description": "Maximize test coverage quickly with parallel module subagents and aggressive testability refactoring",
      "template": "Use the `aggressive-testing` skill to maximize meaningful test coverage across the codebase. Additional user instructions: $ARGUMENTS",
      "agent": "build"
    },
    "bump-rust-deps": {
      "description": "Bump Rust dependencies using the bump-rust-deps skill",
      "template": "Use the `bump-rust-deps` skill to update Rust dependencies with per-bump verification. Additional user instructions: $ARGUMENTS",
      "agent": "build"
    },
    "eval": {
      "description": "Evaluate options and recommend best approach",
      "template": "You are evaluating a decision question. If $ARGUMENTS is non-empty, treat it as the target proposal/question. If $ARGUMENTS is empty, use the most recent unresolved assistant question in this chat that asks the user to choose between two or more solutions. If no clear unresolved multi-option question exists, do not guess; ask the user to paste the exact question to evaluate. Requirements: 1) Propose 2-4 viable approaches. 2) For each approach, weigh pros and cons, including risks and effort. 3) Explore at least one alternative that could improve on the leading option. 4) End with one clear recommendation and why it is the best tradeoff. Output format: Options considered; Tradeoffs (pros/cons); Better alternatives explored; Final recommendation.",
      "agent": "plan"
    },
    "add-private-mcp": {
      "description": "Add or update private MCP server config",
      "template": "Use the `add-private-mcp` skill to add or update an MCP server in private dotfiles config. Do not write placeholders for missing secrets; ask the user for required token values. Additional user instructions: $ARGUMENTS",
      "agent": "build"
    },
    "pr": {
      "description": "Create a pull request using the pr skill",
      "template": "Use the `pr` skill to prepare and open a GitHub pull request from the current branch. Additional user instructions: $ARGUMENTS",
      "agent": "build"
    },
    "rebase": {
      "description": "Rebase safely using the rebase skill",
      "template": "Use the `rebase` skill to run a safe rebase workflow for the current branch. Additional user instructions: $ARGUMENTS",
      "agent": "build"
    },
    "task-plan": {
      "description": "Plan work before edits",
      "template": "First produce a concise implementation plan for: $ARGUMENTS. After the plan, list assumptions and risky edge cases.",
      "agent": "plan"
    },
    "task-check": {
      "description": "Review staged changes",
      "template": "Review the staged changes and give a short checklist of risks, tests, and release notes.",
      "agent": "build"
    }
  },
  "permission": {
