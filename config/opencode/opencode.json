{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4.7",
  "small_model": "openai/gpt-5.4",
  "autoupdate": false,
  "share": "manual",
  "watcher": {
    "ignore": [
      ".git/**",
      ".direnv/**",
      "node_modules/**",
      "target/**",
      "dist/**",
      "build/**"
    ]
  },
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "./scripts/*.sh *": "allow",
      "asdf *": "allow",
      "awk *": "allow",
      "bash *": "allow",
      "basename *": "allow",
      "brew *": "allow",
      "cat *": "allow",
      "cargo check *": "allow",
      "cargo run -q *": "allow",
      "cargo run -- *": "allow",
      "cargo test *": "allow",
      "cargo tree *": "allow",
      "cargo *": "allow",
      "cd *": "allow",
      "command *": "allow",
      "corepack *": "allow",
      "cp *": "allow",
      "curl *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "df *": "allow",
      "du *": "allow",
      "docker *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "export *": "allow",
      "fast-chg *": "allow",
      "file *": "allow",
      "find *": "allow",
      "for *": "allow",
      "gh": "allow",
      "gh pr *": "allow",
      "gh pr create *": "allow",
      "gh pr create --base * --head * --title * --body *": "allow",
      "gh *": "allow",
      "gh repo view *": "allow",
      "git add *": "allow",
      "git am *": "allow",
      "git apply *": "allow",
      "git branch *": "allow",
      "git branch -vv": "allow",
      "git -C *": "allow",
      "git checkout *": "allow",
      "git clone *": "allow",
      "git commit*": "allow",
      "git config *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git diff --stat *...HEAD": "allow",
      "git fetch *": "allow",
      "git format-patch *": "allow",
      "git init *": "allow",
      "git --git-dir *": "allow",
      "git --git-dir=*": "allow",
      "git ls-files *": "allow",
      "git ls-remote*": "allow",
      "git ls-tree *": "allow",
      "git log *": "allow",
      "git log --oneline *..HEAD": "allow",
      "git merge-base *": "allow",
      "git mv *": "allow",
      "git pull *": "allow",
      "git push*": "allow",
      "git push -u origin *": "allow",
      "git range-diff *": "allow",
      "git rebase *": "allow",
      "git remote -v": "allow",
      "git remote -v *": "allow",
      "git remote add *": "allow",
      "git remote get-url *": "allow",
      "git remote show *": "allow",
      "git reset *": "allow",
      "git restore *": "allow",
      "git rev-list *": "allow",
      "git rev-parse *": "allow",
      "git rev-parse --abbrev-ref HEAD": "allow",
      "git show*": "allow",
      "git show ref *": "allow",
      "git show-ref *": "allow",
      "git stash": "allow",
      "git stash *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git status --porcelain*": "allow",
      "git status --short --branch": "allow",
      "git submodule *": "allow",
      "git symbolic-ref *": "allow",
      "git worktree *": "allow",
      "git *": "allow",
      "glab api *": "allow",
      "glab *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "if *": "allow",
      "jq *": "allow",
      "journalctl *": "allow",
      "just *": "allow",
      "kstack *": "allow",
      "lsof *": "allow",
      "ls *": "allow",
      "make *": "allow",
      "mint *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "nix develop *": "allow",
      "nix-daemon *": "allow",
      "nix-env *": "allow",
      "nix *": "allow",
      "node *": "allow",
      "npm view *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "opencode *": "allow",
      "pg_isready *": "allow",
      "pgrep *": "allow",
      "pnpm --filter *": "allow",
      "pnpm *": "allow",
      "pod *": "allow",
      "printf *": "allow",
      "promtool *": "allow",
      "ps *": "allow",
      "psql -h *": "allow",
      "psql *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "readlink *": "allow",
      "rg *": "allow",
      "rm *": "allow",
      "rustc *": "allow",
      "rustup *": "allow",
      "rustup run *": "allow",
      "sbs *": "allow",
      "sccache *": "allow",
      "security *": "allow",
      "sed *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "sqlite3 *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "task check *": "allow",
      "task list *": "allow",
      "task rebase *": "allow",
      "task start *": "allow",
      "task *": "allow",
      "terraform *": "allow",
      "test *": "allow",
      "time *": "allow",
      "timeout *": "allow",
      "tmux *": "allow",
      "touch *": "allow",
      "tr *": "allow",
      "true": "allow",
      "wc *": "allow",
      "wget *": "allow",
      "which *": "allow",
      "yarn *": "allow",
      "xargs *": "allow",
      "xxd *": "allow",
      "xz *": "allow",
      "~/dev/dotfiles/setup.sh": "allow",
      "~/dev/dotfiles/setup.sh *": "allow",
      "API_KEY=*": "allow",
      "BASE_REF=*": "allow",
      "BRANCH=*": "allow",
      "DOTFILES=*": "allow",
      "GLAB_TOKEN=*": "allow",
      "GIT_DIR=*": "allow",
      "GIT_EDITOR=true git rebase --continue": "allow",
      "GITLAB_HOST=*": "allow",
      "GITLAB_TOKEN=*": "allow",
      "NOMAD_ADDR=*": "allow",
      "NEW_TOKEN=*": "allow",
      "OWNER=*": "allow",
      "RUST_BACKTRACE=*": "allow",
      "RUST_LOG=*": "allow",
      "RUSTC_WRAPPER=*": "allow",
      "SCCACHE_DISABLE=*": "allow",
      "TOKEN=*": "allow",
      "TREEFMT_TREE_ROOT*": "allow"
    },
    "edit": {
      ".env*": "deny",
      "*": "allow"
    },
    "read": {
      ".env*": "deny",
      "*": "allow",
      "/nix/store/**": "allow"
    },
    "external_directory": {
      "~/.cargo/**": "allow",
      "~/.config/**": "allow",
      "~/.local/share/**": "allow",
      "~/dev/**": "allow",
      "/mnt/linux/dotfiles/**": "allow",
      "/mnt/linux/dev/**": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow"
  }
}
