# ~/.zshrc — managed by dotfiles repo (config/shell/zshrc).
# Private overrides go in ~/.config/dotfiles/extras.zsh, which is
# sourced at the end of this file.

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Nix (survives macOS updates unlike /etc/zshrc)
if [ -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh' ]; then
  . '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
fi

export LANG=en_US.UTF-8
export LC_ALL=$LANG
export DRACULA_ARROW_ICON='%{%G🦀%}'
export GPG_TTY=$(tty)

# Wayland support for various GUI toolkits — mirrored in
# config/fish/config.fish. Linux-only (XDG_SESSION_TYPE is unset on
# macOS, so the guard is a no-op there).
if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]; then
    export WAYLAND=1
    export QT_QPA_PLATFORM='wayland;xcb'
    export GDK_BACKEND='wayland,x11'
    export MOZ_DBUS_REMOTE=1
    export MOZ_ENABLE_WAYLAND=1
    export _JAVA_AWT_WM_NONREPARENTING=1
    export BEMENU_BACKEND=wayland
    export CLUTTER_BACKEND=wayland
    export ECORE_EVAS_ENGINE=wayland_egl
    export ELM_ENGINE=wayland_egl
fi

# Homebrew (macOS) on PATH if present.
[[ -d /opt/homebrew/bin ]] && export PATH=/opt/homebrew/bin:$PATH
[[ -d /usr/local/bin ]] && export PATH=/usr/local/bin:$PATH
if command -v go >/dev/null 2>&1; then
  export PATH=$(go env GOPATH)/bin:$PATH
fi

export EDITOR=hx
export VISUAL="$EDITOR"

# Make 'less' use syntax highlighting (homebrew-provided)
if [[ -x /opt/homebrew/bin/src-hilite-lesspipe.sh ]]; then
  export LESSOPEN="| /opt/homebrew/bin/src-hilite-lesspipe.sh %s"
fi

# Zoxide. The `j` alias for `z` is generated by
# home/programs/cross-shell-aliases.nix.
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init --hook pwd zsh)"
fi

# `rd` and `backup` are PATH scripts (home/programs/scripts.nix).
# `cd-task`, `y`, `history` are codegen'd cross-shell functions
# (home/programs/cross-shell-functions.nix). The loader below sources
# every generated zsh function file.
[[ -f ~/.config/zsh/common-functions.zsh ]] && source ~/.config/zsh/common-functions.zsh

# Powerlevel10k = Alacritty theme (homebrew-installed)
[[ -f /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme ]] && \
  source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
[[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
[[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# zsh/Oh my zsh
export ZSH="$HOME/.oh-my-zsh"
plugins=(git)
[[ -f $ZSH/oh-my-zsh.sh ]] && source $ZSH/oh-my-zsh.sh

setopt inc_append_history
setopt share_history
setopt extended_history
setopt hist_expire_dups_first
unsetopt no_share_history
unsetopt hist_ignore_dups

# Add asdf completions
fpath=(${ASDF_DATA_DIR:-$HOME/.asdf}/completions $fpath)

# Auto-complete
autoload -Uz bashcompinit
bashcompinit

# ASDF / Corepack
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
export ASDF_NODEJS_AUTO_ENABLE_COREPACK=yes

# Kafka / SSL / mcrypt
export LIBRARY_PATH=/opt/homebrew/lib
export OPENSSL_ROOT_DIR=/opt/homebrew/opt/openssl@1.1

# openssl, needed to build some libs
if command -v brew >/dev/null 2>&1; then
  OPENSSL_PREFIX=$(brew --prefix openssl)
  export PATH="${OPENSSL_PREFIX}/bin:$PATH"
  export PKG_CONFIG_PATH="${OPENSSL_PREFIX}/lib/pkgconfig:${PKG_CONFIG_PATH}"

  # cyrus-sasl, why is this needed?
  SASL_PREFIX=$(brew --prefix cyrus-sasl)
  export PKG_CONFIG_PATH="${PKG_CONFIG_PATH}:${SASL_PREFIX}/lib/pkgconfig"

  # For rdkafka
  HOMEBREW_DIR=$(brew --prefix)
  export LIBRARY_PATH="${HOMEBREW_DIR}/lib"
  export OPENSSL_ROOT_DIR=${OPENSSL_PREFIX}
fi

# Increasing the maximum number of open file descriptors solves the following errors:
#  * code: 24, kind: Uncategorized, message: "Too many open files"
#  * code: 14, message: "unable to open database ..."
# These errors can appear while running: cargo test --workspace
ulimit -S -n 8192

# Cross-shell common env vars (generated from home/sessionEnv.nix).
[[ -f ~/.config/zsh/common-env.zsh ]] && source ~/.config/zsh/common-env.zsh

# Cross-shell common aliases (generated from home/programs/aliases.nix).
[[ -f ~/.config/zsh/common-aliases.zsh ]] && source ~/.config/zsh/common-aliases.zsh
# Zsh-only aliases live inline below, but the public set is empty.
# Machine-private aliases live in ~/.config/dotfiles/extras.zsh which
# is sourced near the bottom of this file.

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# Completions: include HM-managed dir first so generated functions
# (e.g. `_task`) load via autoload before compinit runs.
fpath=(~/.config/zsh/completions ~/.zsh/completions $HOME/.docker/completions $fpath)
autoload -Uz compinit
compinit

# Private extras
[[ -f ~/.config/dotfiles/extras.zsh ]] && source ~/.config/dotfiles/extras.zsh
