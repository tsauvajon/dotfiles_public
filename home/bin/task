#!/usr/bin/env bash
set -euo pipefail

DEV_ROOT="${DEV_ROOT:-$HOME/dev}"
REPOS_DIR="${DEV_ROOT}/repos"
WT_DIR="${DEV_ROOT}/wt"

log() {
  printf '==> %s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

usage() {
  printf 'Usage:\n'
  printf '  task <command> [arguments]\n\n'
  printf 'Commands:\n'
  printf '  %-34s %s\n' 'bootstrap' 'Prepare workspace and asdf Node plugin'
  printf '  %-34s %s\n' 'doctor' 'Check toolchain and workspace health'
  printf '  %-34s %s\n' 'clone <repo-url> [repo-key]' 'Clone bare repo into ~/dev/repos'
  printf '  %-34s %s\n' 'start <repo|url> <branch> [base]' 'Create/open a task worktree'
  printf '  %-34s %s\n' 'open <repo> <branch>' 'Re-open a parked task'
  printf '  %-34s %s\n' 'park' 'Park current task (stop tmux session)'
  printf '  %-34s %s\n' 'path <repo> <branch>' 'Print worktree path for a task'
  printf '  %-34s %s\n' 'list [repo]' 'List tasks with open/parked status'
  printf '  %-34s %s\n' 'worktrees [repo]' 'Show raw git worktree list output'
  printf '  %-34s %s\n' 'clean <repo> <branch> [--force]' 'Remove a task worktree'
  printf '  %-34s %s\n' 'prune <repo>' 'Prune stale worktree metadata'
  printf '  %-34s %s\n' 'done [worktree-path]' 'Run project checks for current task'
  printf '\nConventions:\n'
  printf '  DEV_ROOT defaults to ~/dev\n'
  printf '  Bare repos live in ~/dev/repos\n'
  printf '  Worktrees live in ~/dev/wt\n'
}

ensure_layout() {
  mkdir -p "$REPOS_DIR" "$WT_DIR"
}

is_git_url() {
  case "$1" in
    http://*|https://*|ssh://*|git@*:*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

normalize_repo_key() {
  local input="$1"
  local key

  if is_git_url "$input"; then
    key="$input"
    key="${key#ssh://}"
    key="${key#https://}"
    key="${key#http://}"

    if [[ "$key" == git@*:* ]]; then
      key="${key#git@}"
      key="${key/:/\/}"
    fi

    key="${key%.git}"
  else
    key="${input#/}"
    key="${key%.git}"
  fi

  printf '%s\n' "$key"
}

matching_repo_keys() {
  local query="$1"
  local gitdir
  local key
  local base

  [[ -d "$REPOS_DIR" ]] || return 0

  while IFS= read -r gitdir; do
    key="${gitdir#${REPOS_DIR}/}"
    key="${key%.git}"
    base="${key##*/}"

    if [[ "$key" == "$query" ]] || [[ "$base" == "$query" ]] || [[ "$key" == */"$query" ]]; then
      printf '%s\n' "$key"
    fi
  done < <(find "$REPOS_DIR" -type d -name '*.git' | sort)
}

choose_repo_key_interactive() {
  local query="$1"
  shift
  local -a choices=("$@")
  local selected

  if [[ ! -t 0 || ! -t 1 ]]; then
    die "Multiple repositories match '$query': ${choices[*]}. Please use a full repo key."
  fi

  if command -v fzf >/dev/null 2>&1; then
    selected="$(printf '%s\n' "${choices[@]}" | fzf --prompt="repo> " --height=40% --reverse --border --header="Multiple repos match '$query' - choose one")"
    [[ -n "$selected" ]] || die "Selection cancelled."
    printf '%s\n' "$selected"
    return 0
  fi

  die "Multiple repositories match '$query': ${choices[*]}. Install fzf or use a full repo key."
}

resolve_repo_key() {
  local repo_arg="$1"
  local normalized
  local exact_gitdir
  local matches_text
  local -a matches

  if is_git_url "$repo_arg"; then
    normalize_repo_key "$repo_arg"
    return 0
  fi

  normalized="$(normalize_repo_key "$repo_arg")"
  exact_gitdir="$(repo_gitdir_path "$normalized")"
  if [[ -d "$exact_gitdir" ]]; then
    printf '%s\n' "$normalized"
    return 0
  fi

  matches_text="$(matching_repo_keys "$normalized")"
  if [[ -n "$matches_text" ]]; then
    mapfile -t matches <<< "$matches_text"
  else
    matches=()
  fi

  if [[ "${#matches[@]}" -eq 0 ]]; then
    printf '%s\n' "$normalized"
    return 0
  fi

  if [[ "${#matches[@]}" -eq 1 ]]; then
    printf '%s\n' "${matches[0]}"
    return 0
  fi

  choose_repo_key_interactive "$repo_arg" "${matches[@]}"
}

repo_gitdir_path() {
  local repo_key="$1"
  printf '%s/%s.git\n' "$REPOS_DIR" "$repo_key"
}

worktree_path() {
  local repo_key="$1"
  local branch="$2"
  printf '%s/%s/%s\n' "$WT_DIR" "$repo_key" "$branch"
}

clone_bare_repo() {
  local repo_url="$1"
  local repo_key="$2"
  local gitdir

  gitdir="$(repo_gitdir_path "$repo_key")"
  if [[ -d "$gitdir" ]]; then
    return 0
  fi

  log "Cloning bare repo: $repo_url"
  mkdir -p "$(dirname "$gitdir")"
  git clone --bare "$repo_url" "$gitdir"
}

ensure_repo_available() {
  local repo_arg="$1"
  local repo_key="$2"
  local gitdir

  gitdir="$(repo_gitdir_path "$repo_key")"
  if [[ -d "$gitdir" ]]; then
    return 0
  fi

  if is_git_url "$repo_arg"; then
    clone_bare_repo "$repo_arg" "$repo_key"
    return 0
  fi

  die "Bare repo not found at $gitdir. Use 'task clone <repo-url> ${repo_key}'."
}

detect_default_base() {
  local gitdir="$1"

  if git --git-dir "$gitdir" show-ref --verify --quiet refs/remotes/origin/main; then
    printf 'origin/main\n'
    return 0
  fi

  if git --git-dir "$gitdir" show-ref --verify --quiet refs/remotes/origin/master; then
    printf 'origin/master\n'
    return 0
  fi

  if git --git-dir "$gitdir" symbolic-ref --quiet --short refs/remotes/origin/HEAD >/dev/null 2>&1; then
    git --git-dir "$gitdir" symbolic-ref --quiet --short refs/remotes/origin/HEAD
    return 0
  fi

  printf 'HEAD\n'
}

session_name_for() {
  local repo_key="$1"
  local branch="$2"
  local name

  name="$(printf '%s' "${repo_key}-${branch}" | tr '/:.' '_' | tr -cd '[:alnum:]_-')"
  name="${name:0:80}"
  if [[ -z "$name" ]]; then
    name="devtask"
  fi
  printf '%s\n' "$name"
}

launch_workspace() {
  local repo_key="$1"
  local branch="$2"
  local path="$3"
  local session

  if [[ -f "$path/.envrc" ]] && command -v direnv >/dev/null 2>&1; then
    (cd "$path" && direnv allow >/dev/null 2>&1 || true)
  fi

  if [[ -f "$path/.tool-versions" ]] && command -v asdf >/dev/null 2>&1; then
    (cd "$path" && asdf install)
    if command -v corepack >/dev/null 2>&1; then
      corepack enable >/dev/null 2>&1 || true
    fi
  fi

  if command -v codium >/dev/null 2>&1; then
    codium "$path" >/dev/null 2>&1 &
  fi

  if command -v tmux >/dev/null 2>&1; then
    session="$(session_name_for "$repo_key" "$branch")"
    if ! tmux has-session -t "$session" 2>/dev/null; then
      tmux new-session -d -s "$session" -c "$path"
    fi

    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$session"
    else
      exec tmux attach-session -t "$session"
    fi
    return 0
  fi

  printf '%s\n' "$path"
}

current_task_info() {
  local root
  local common_dir
  local repo_key
  local branch
  local marker

  root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$root" ]] || die "Not inside a git repository. Run 'task list' to see parkable tasks."
  root="$(cd "$root" && pwd -P)"

  common_dir="$(git -C "$root" rev-parse --git-common-dir 2>/dev/null || true)"
  [[ -n "$common_dir" ]] || die "Could not determine git common dir. Run 'task list' to inspect tasks."

  if [[ "$common_dir" != /* ]]; then
    common_dir="$root/$common_dir"
  fi
  common_dir="$(cd "$common_dir" 2>/dev/null && pwd -P || true)"
  [[ -n "$common_dir" ]] || die "Could not resolve git common dir path."

  case "$common_dir" in
    */repos/*.git)
      ;;
    *)
      die "Current repository is not managed by task. Run 'task list' to see parkable tasks."
      ;;
  esac

  repo_key="${common_dir#*/repos/}"
  repo_key="${repo_key%.git}"

  branch="$(git -C "$root" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -z "$branch" ]]; then
    marker="/wt/${repo_key}/"
    if [[ "$root" == *"$marker"* ]]; then
      branch="${root#*${marker}}"
    fi
    if [[ -z "$branch" ]]; then
      branch="$(basename "$root")"
    fi
  fi

  [[ -n "$branch" ]] || die "Could not determine current task branch. Run 'task list' to inspect tasks."

  printf '%s\n%s\n%s\n' "$repo_key" "$branch" "$root"
}

task_status_for() {
  local session="$1"
  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$session" 2>/dev/null; then
    printf 'open\n'
  else
    printf 'parked\n'
  fi
}

emit_task_row() {
  local repo_key="$1"
  local path="$2"
  local branch_ref="$3"
  local branch
  local marker
  local session
  local status

  if [[ -n "$branch_ref" ]]; then
    branch="${branch_ref#refs/heads/}"
  else
    marker="/wt/${repo_key}/"
    if [[ "$path" == *"$marker"* ]]; then
      branch="${path#*${marker}}"
    else
      branch="$(basename "$path")"
    fi
  fi

  session="$(session_name_for "$repo_key" "$branch")"
  status="$(task_status_for "$session")"

  printf '%-7s %-35s %-28s %s\n' "$status" "$repo_key" "$branch" "$path"
  return 0
}

print_repo_tasks() {
  local gitdir="$1"
  local repo_key="$2"
  local line
  local path=""
  local branch_ref=""
  local is_bare=0
  local printed=0

  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        if [[ -n "$path" ]]; then
          if [[ "$is_bare" -eq 0 ]] && emit_task_row "$repo_key" "$path" "$branch_ref"; then
            printed=1
          fi
        fi
        path="${line#worktree }"
        branch_ref=""
        is_bare=0
        ;;
      branch\ *)
        branch_ref="${line#branch }"
        ;;
      bare)
        is_bare=1
        ;;
      '')
        if [[ -n "$path" ]]; then
          if [[ "$is_bare" -eq 0 ]] && emit_task_row "$repo_key" "$path" "$branch_ref"; then
            printed=1
          fi
          path=""
          branch_ref=""
          is_bare=0
        fi
        ;;
    esac
  done < <(git --git-dir "$gitdir" worktree list --porcelain)

  if [[ -n "$path" ]]; then
    if [[ "$is_bare" -eq 0 ]] && emit_task_row "$repo_key" "$path" "$branch_ref"; then
      printed=1
    fi
  fi

  [[ "$printed" -eq 1 ]]
}

cmd_clone() {
  local repo_url="${1:-}"
  local repo_key="${2:-}"

  [[ -n "$repo_url" ]] || die "Missing repo URL."
  ensure_layout

  if [[ -z "$repo_key" ]]; then
    repo_key="$(normalize_repo_key "$repo_url")"
  fi

  clone_bare_repo "$repo_url" "$repo_key"
  log "Repo key: $repo_key"
}

cmd_start() {
  local repo_arg="${1:-}"
  local branch="${2:-}"
  local base_ref="${3:-}"
  local repo_key
  local gitdir
  local path

  [[ -n "$repo_arg" ]] || die "Missing repo argument."
  [[ -n "$branch" ]] || die "Missing branch name."

  ensure_layout
  repo_key="$(resolve_repo_key "$repo_arg")"
  gitdir="$(repo_gitdir_path "$repo_key")"

  ensure_repo_available "$repo_arg" "$repo_key"
  git --git-dir "$gitdir" fetch --all --prune

  if [[ -z "$base_ref" ]]; then
    base_ref="$(detect_default_base "$gitdir")"
  fi

  path="$(worktree_path "$repo_key" "$branch")"

  if [[ -e "$path" ]] && [[ ! -e "$path/.git" ]]; then
    die "Path exists but is not a git worktree: $path"
  fi

  if [[ -e "$path/.git" ]]; then
    log "Reusing existing worktree: $path"
    launch_workspace "$repo_key" "$branch" "$path"
    return 0
  fi

  mkdir -p "$(dirname "$path")"

  if git --git-dir "$gitdir" show-ref --verify --quiet "refs/heads/$branch"; then
    git --git-dir "$gitdir" worktree add "$path" "$branch"
  elif git --git-dir "$gitdir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    git --git-dir "$gitdir" worktree add --track -b "$branch" "$path" "origin/$branch"
  else
    if ! git --git-dir "$gitdir" rev-parse --verify --quiet "${base_ref}^{commit}" >/dev/null; then
      die "Base ref not found: $base_ref"
    fi
    git --git-dir "$gitdir" worktree add -b "$branch" "$path" "$base_ref"
  fi

  launch_workspace "$repo_key" "$branch" "$path"
}

cmd_open() {
  local repo_key
  local branch="${2:-}"
  local path

  repo_key="$(resolve_repo_key "${1:-}")"
  [[ -n "$repo_key" ]] || die "Missing repo key."
  [[ -n "$branch" ]] || die "Missing branch name."

  path="$(worktree_path "$repo_key" "$branch")"
  [[ -e "$path/.git" ]] || die "Worktree not found: $path"

  launch_workspace "$repo_key" "$branch" "$path"
}

cmd_park() {
  local -a info
  local info_text
  local repo_key
  local branch
  local path
  local session

  [[ "$#" -eq 0 ]] || die "task park takes no arguments. Run it inside a task worktree."

  ensure_layout
  info_text="$(current_task_info)"
  mapfile -t info <<< "$info_text"
  repo_key="${info[0]}"
  branch="${info[1]}"
  path="${info[2]}"
  session="$(session_name_for "$repo_key" "$branch")"

  if ! command -v tmux >/dev/null 2>&1; then
    die "tmux is not available. Run 'task list' to inspect tasks."
  fi

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    log "Parked task: $repo_key $branch"
  else
    log "Task already parked: $repo_key $branch"
  fi

  printf '%s\n' "$path"
}

cmd_path() {
  local repo_key
  local branch="${2:-}"

  repo_key="$(resolve_repo_key "${1:-}")"
  [[ -n "$repo_key" ]] || die "Missing repo key."
  [[ -n "$branch" ]] || die "Missing branch name."

  worktree_path "$repo_key" "$branch"
}

cmd_list() {
  local repo_arg="${1:-}"
  local gitdir
  local repo_key
  local found=0

  ensure_layout

  if [[ -n "$repo_arg" ]]; then
    repo_key="$(resolve_repo_key "$repo_arg")"
    gitdir="$(repo_gitdir_path "$repo_key")"
    [[ -d "$gitdir" ]] || die "Repo not found: $repo_key"
    printf '%-7s %-35s %-28s %s\n' "STATUS" "REPO" "BRANCH" "PATH"
    if print_repo_tasks "$gitdir" "$repo_key"; then
      found=1
    fi
    if [[ "$found" -eq 0 ]]; then
      log "No tasks found for $repo_key"
    fi
    return 0
  fi

  printf '%-7s %-35s %-28s %s\n' "STATUS" "REPO" "BRANCH" "PATH"

  while IFS= read -r gitdir; do
    repo_key="${gitdir#${REPOS_DIR}/}"
    repo_key="${repo_key%.git}"
    if print_repo_tasks "$gitdir" "$repo_key"; then
      found=1
    fi
  done < <(find "$REPOS_DIR" -type d -name '*.git' | sort)

  if [[ "$found" -eq 0 ]]; then
    log "No tasks found under $WT_DIR"
  fi
}

cmd_worktrees() {
  local repo_arg="${1:-}"
  local gitdir
  local repo_key
  local found=0

  ensure_layout

  if [[ -n "$repo_arg" ]]; then
    repo_key="$(resolve_repo_key "$repo_arg")"
    gitdir="$(repo_gitdir_path "$repo_key")"
    [[ -d "$gitdir" ]] || die "Repo not found: $repo_key"
    git --git-dir "$gitdir" worktree list
    return 0
  fi

  while IFS= read -r gitdir; do
    found=1
    repo_key="${gitdir#${REPOS_DIR}/}"
    repo_key="${repo_key%.git}"
    printf '\n[%s]\n' "$repo_key"
    git --git-dir "$gitdir" worktree list
  done < <(find "$REPOS_DIR" -type d -name '*.git' | sort)

  if [[ "$found" -eq 0 ]]; then
    log "No repositories found in $REPOS_DIR"
  fi
}

cmd_clean() {
  local repo_key
  local branch
  local force="${3:-}"
  local gitdir
  local path

  repo_key="$(resolve_repo_key "${1:-}")"
  branch="${2:-}"

  [[ -n "$repo_key" ]] || die "Missing repo key."
  [[ -n "$branch" ]] || die "Missing branch name."

  gitdir="$(repo_gitdir_path "$repo_key")"
  path="$(worktree_path "$repo_key" "$branch")"

  [[ -d "$gitdir" ]] || die "Repo not found: $repo_key"
  [[ -e "$path/.git" ]] || die "Worktree not found: $path"

  if [[ "$force" != "--force" ]] && [[ -n "$(git -C "$path" status --porcelain)" ]]; then
    die "Worktree has uncommitted changes. Use --force if you really want to remove it."
  fi

  if [[ "$force" == "--force" ]]; then
    git --git-dir "$gitdir" worktree remove --force "$path"
  else
    git --git-dir "$gitdir" worktree remove "$path"
  fi

  rmdir "$(dirname "$path")" 2>/dev/null || true
}

cmd_prune() {
  local repo_key
  local gitdir

  repo_key="$(resolve_repo_key "${1:-}")"
  [[ -n "$repo_key" ]] || die "Missing repo key."

  gitdir="$(repo_gitdir_path "$repo_key")"
  [[ -d "$gitdir" ]] || die "Repo not found: $repo_key"

  git --git-dir "$gitdir" worktree prune --verbose
}

cmd_done() {
  local path="${1:-$PWD}"
  local checked=0
  local -a pnpm_cmd

  [[ -d "$path" ]] || die "Path not found: $path"
  cd "$path"

  if [[ -f "Cargo.toml" ]]; then
    checked=1
    log "Running Rust checks"
    cargo fmt --all --check
    cargo clippy --workspace --all-targets --all-features -- -D warnings
    cargo test --workspace --all-features
  fi

  if [[ -f "package.json" ]]; then
    checked=1
    log "Running JS checks"

    if command -v corepack >/dev/null 2>&1; then
      corepack enable >/dev/null 2>&1 || true
    fi

    pnpm_cmd=()
    if command -v pnpm >/dev/null 2>&1; then
      pnpm_cmd=(pnpm)
    elif command -v corepack >/dev/null 2>&1; then
      pnpm_cmd=(corepack pnpm)
    fi

    if [[ "${#pnpm_cmd[@]}" -eq 0 ]]; then
      warn "pnpm/corepack not found. Skipping JS checks."
    else
      "${pnpm_cmd[@]}" install --frozen-lockfile || "${pnpm_cmd[@]}" install
      "${pnpm_cmd[@]}" run lint --if-present
      "${pnpm_cmd[@]}" run check --if-present
      "${pnpm_cmd[@]}" run test --if-present
      "${pnpm_cmd[@]}" run build --if-present
    fi
  fi

  if [[ "$checked" -eq 0 ]]; then
    warn "No Cargo.toml or package.json found. Nothing to run."
  fi
}

cmd_bootstrap() {
  local asdf_data_dir
  local import_script

  ensure_layout
  log "Workspace root: $DEV_ROOT"

  if command -v asdf >/dev/null 2>&1; then
    if ! asdf plugin list 2>/dev/null | grep -q '^nodejs$'; then
      log "Installing asdf nodejs plugin"
      asdf plugin add nodejs https://github.com/asdf-vm/asdf-nodejs.git
    fi

    asdf_data_dir="${ASDF_DATA_DIR:-$HOME/.asdf}"
    import_script="${asdf_data_dir}/plugins/nodejs/bin/import-release-team-keyring"
    if [[ -x "$import_script" ]]; then
      "$import_script" || warn "Could not import nodejs release keyring."
    fi

    if [[ -f "$HOME/.tool-versions" ]]; then
      log "Installing runtimes from ~/.tool-versions"
      asdf install
    fi
  else
    warn "asdf not found. Install toolchain first (nix profile install path:~/flakes#toolchain)."
  fi

  if command -v node >/dev/null 2>&1 && command -v corepack >/dev/null 2>&1; then
    corepack enable >/dev/null 2>&1 || true
  fi

  log "Bootstrap complete"
}

cmd_doctor() {
  local missing=0
  local cmd

  printf 'DEV_ROOT: %s\n' "$DEV_ROOT"
  for cmd in git tmux vim codium opencode nix direnv asdf; do
    if command -v "$cmd" >/dev/null 2>&1; then
      printf '[ok]      %s\n' "$cmd"
    else
      printf '[missing] %s\n' "$cmd"
      missing=1
    fi
  done

  if [[ -d "$REPOS_DIR" && -d "$WT_DIR" ]]; then
    printf '[ok]      %s\n' "$DEV_ROOT layout"
  else
    printf '[missing] %s\n' "$DEV_ROOT layout"
    missing=1
  fi

  if command -v opencode >/dev/null 2>&1; then
    if opencode auth list >/dev/null 2>&1; then
      printf '[ok]      opencode auth storage reachable\n'
    else
      printf '[warn]    opencode auth storage not initialized yet\n'
    fi
  fi

  return "$missing"
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    usage
    exit 1
  fi

  shift || true
  case "$cmd" in
    bootstrap) cmd_bootstrap "$@" ;;
    doctor) cmd_doctor "$@" ;;
    clone) cmd_clone "$@" ;;
    start) cmd_start "$@" ;;
    open) cmd_open "$@" ;;
    park) cmd_park "$@" ;;
    path) cmd_path "$@" ;;
    list) cmd_list "$@" ;;
    worktrees) cmd_worktrees "$@" ;;
    clean) cmd_clean "$@" ;;
    prune) cmd_prune "$@" ;;
    done) cmd_done "$@" ;;
    -h|--help|help) usage ;;
    *)
      die "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
