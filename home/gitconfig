[init]
	defaultBranch = master
[user]
	email = YOUR_EMAIL
	name = YOUR_NAME
	signingkey = YOUR_GPG_KEY_ID
[core]
	editor = vim
	pager = delta
[push]
	autoSetupRemote = true
[commit]
	gpgsign = true
[pack]
	windowMemory = 100m
	packSizeLimit = 100m
	threads = 1
	deltaCacheSize = 512m
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	format = openpgp
[include]
	path = ~/.config/dotfiles/extra.gitconfig

# Delta config
[interactive]
	diffFilter = delta --color-only
[delta]
	paging = always
	navigate = true # use n and N to move between diff sections
	dark = true # omit for auto-detection
	side-by-side = true
	line-numbers = true
	hyperlinks=true
	# hyperlinks-file-link-format = "idea://open?file={path}&line={line}
[merge]
	conflictStyle = zdiff3
	tool = vimdiff
[mergetool]
	prompt = false
