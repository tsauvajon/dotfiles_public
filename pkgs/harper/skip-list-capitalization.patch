+/// Returns true if `word_start` is the first word of a markdown list item:
+/// preceded on the same line only by whitespace and a list marker (`-`, `*`,
+/// `+`, or digits followed by `.` or `)`).
+fn begins_in_markdown_list_item(source: &[char], word_start: usize) -> bool {
+    if word_start == 0 || word_start > source.len() {
+        return false;
+    }
+
+    let mut line_start = word_start;
+    while line_start > 0 && source[line_start - 1] != '\n' {
+        line_start -= 1;
+    }
+
+    let mut i = line_start;
+    while i < word_start && source[i].is_whitespace() {
+        i += 1;
     }
+    if i >= word_start {
+        return false;
+    }
+
+    if matches!(source[i], '-' | '*' | '+') {
+        return i + 1 < word_start && source[i + 1].is_whitespace();
+    }
+
+    if source[i].is_ascii_digit() {
+        let mut j = i + 1;
+        while j < word_start && source[j].is_ascii_digit() {
+            j += 1;
+        }
+        return j < word_start
+            && matches!(source[j], '.' | ')')
+            && j + 1 < word_start
+            && source[j + 1].is_whitespace();
+    }
+
+    false
 }
 
