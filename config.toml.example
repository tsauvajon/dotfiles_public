# Copy to ~/.config/dotfiles/config.toml and fill in real values.

[git]
name = "Your Full Name"
email = "you@example.com"
signing_key = "0000000000000000"  # 16-char hex key ID — run: gpg --list-secret-keys --keyid-format long

[goto]
# See: https://github.com/tsauvajon/goto
api_url = "http://your-host:50002"

[task]
# Optional — override the default workspace directory paths used by `task`.
# Defaults match the values in config/task/config.toml.
# repos_dir = "~/dev/repos"
# wt_dir = "~/dev/wt"
# detached_dir = "~/dev/detached"

[vscodium]
# See: https://github.com/tsauvajon/task
# Trusted workspace roots — injected into ~/.config/task/config.toml under [vscodium].trusted_roots
trusted_roots = [
  "/home/youruser/dev/wt/github.com/youruser",
  "/home/youruser/dev/repos/github.com/youruser",
]

[dotfiles]
# Destination paths to skip, matched as a suffix relative to $HOME.
# Useful for omitting Linux-only or macOS-only outputs on the other platform.
# Example: skip Wayland configs on macOS:
# skip_destinations = [".config/hypr", ".config/rofi", ".config/mako", ".config/waybar", ".config/wayland-env.sh"]
skip_destinations = []

# Source paths to skip, matched as a suffix relative to the dotfiles repo root.
# Prevents specific repo files from being linked or merged into config.
# Useful for excluding platform-specific overlays (e.g. macOS cargo config on Linux).
# Example: skip macOS-only Cargo overlay on Linux:
# skip_sources = ["home/cargo.darwin.toml"]
skip_sources = []

# Controls how ~/.config/opencode/AGENTS.md is built:
# - merged: public config/opencode/AGENTS.md + private rules overlays (default)
# - private_only: only private rules overlays
# - disabled: do not manage/link AGENTS.md
rules_mode = "merged"

# Private OpenCode skills live at ~/.config/dotfiles/opencode/skills/<skill-name>/SKILL.md
# setup.sh merges them with the public skills from this repo at setup time.
# Private OpenCode agents live at ~/.config/dotfiles/opencode/agents/<name>.md
# setup.sh merges them with public agents from config/opencode/agents/ at setup time.
# Private agents overwrite public ones on filename collision.
# Private OpenCode rules overlays live at ~/.config/dotfiles/opencode/rules/
# setup.sh appends each non-empty readable file in that directory to the generated AGENTS.md.
# Files are appended in filename order (LC_ALL=C), so numeric prefixes work well.
# Private OpenCode JSON overlay lives at ~/.config/dotfiles/opencode/opencode.json.
# setup.sh deep-merges it over config/opencode/opencode.json (private values win).
# Use this for private MCP server entries and other local-only OpenCode overrides.
# Private SSH host config can live at ~/.config/dotfiles/ssh/config.
# The repo-managed ~/.ssh/config includes it first, so keep host-specific entries,
# IdentityFile paths, and machine-only SSH settings there.

# Extra git config can be added to ~/.config/dotfiles/extra.gitconfig
