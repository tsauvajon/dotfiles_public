# Copy to ~/.config/dotfiles/private.toml and fill in real values.

[git]
name = "Your Full Name"
email = "you@example.com"
signing_key = "0000000000000000"  # 16-char hex key ID — run: gpg --list-secret-keys --keyid-format long

[goto]
# See: https://github.com/tsauvajon/goto
api_url = "http://your-host:50002"

[task]
# Optional — override the default workspace directory paths used by `task`.
# Defaults match the values in config/task/config.toml.
# repos_dir = "~/dev/repos"
# wt_dir = "~/dev/wt"
# detached_dir = "~/dev/detached"

[vscodium]
# See: https://github.com/tsauvajon/task
# Trusted workspace roots — injected into ~/.config/task/config.toml under [vscodium].trusted_roots
trusted_roots = [
  "/home/youruser/dev/wt/github.com/youruser",
  "/home/youruser/dev/repos/github.com/youruser",
]

[dotfiles]
# Symlink destinations to skip, matched as a path suffix of the link target relative to $HOME.
# Useful for omitting Linux-only or macOS-only configs on the other platform.
# Example: skip Wayland configs on macOS:
# skip_links = [".config/hypr", ".config/rofi", ".config/mako", ".config/waybar", ".config/wayland-env.sh"]
skip_links = []

# Private OpenCode skills live at ~/.config/dotfiles/private-skills/<skill-name>/SKILL.md
# setup.sh merges them with the public skills from this repo at setup time.
# Private OpenCode AGENTS overlays live at ~/.config/dotfiles/private-AGENTS/
# setup.sh appends each non-empty readable file in that directory to config/opencode/AGENTS.md.
# Files are appended in filename order (LC_ALL=C), so numeric prefixes work well.
# Private OpenCode JSON overlay lives at ~/.config/dotfiles/private-opencode.json.
# setup.sh deep-merges it over config/opencode/opencode.json (private values win).
# Use this for private MCP server entries and other local-only OpenCode overrides.

# Extra git config can be added to ~/.config/dotfiles/extra.gitconfig
