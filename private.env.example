# Copy to ~/.config/dotfiles/private.env and fill in real values.

# Git identity
GIT_NAME="Your Full Name"
GIT_EMAIL="you@example.com"
GIT_SIGNINGKEY="0000000000000000"  # 16-char hex key ID — run: gpg --list-secret-keys --keyid-format long

# goto shortcut manager API endpoint
# See: https://github.com/bknd/goto
GOTO_CONFIG_API_URL="http://your-host:50002"  # used by ~/.config/goto/config.yml
